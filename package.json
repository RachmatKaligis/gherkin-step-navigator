{
  "name": "gherkin-step-navigator",
  "displayName": "Gherkin Step Navigator for RobotCode",
  "description": "Go to Definition and Hover for Gherkin steps in Robot Framework projects. Companion extension for RobotCode GherkinParser Support.",
  "version": "0.1.0",
  "publisher": "RachmatKaligis",
  "author": {
    "name": "Rachmat Kaligis",
    "url": "https://github.com/RachmatKaligis/"
  },
  "license": "MIT",
  "homepage": "https://github.com/RachmatKaligis/gherkin-step-navigator",
  "repository": {
    "type": "git",
    "url": "https://github.com/RachmatKaligis/gherkin-step-navigator"
  },
  "bugs": {
    "url": "https://github.com/RachmatKaligis/gherkin-step-navigator/issues"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Testing",
    "Other"
  ],
  "keywords": [
    "Gherkin",
    "Cucumber",
    "BDD",
    "Robot Framework",
    "RobotCode",
    "RobotFramework",
    "Go to Definition",
    "Navigation",
    "Feature Files",
    "GherkinParser"
  ],
  "extensionDependencies": [
    "d-biehl.robotcode-gherkin"
  ],
  "icon": "icons/icon.png",
  "galleryBanner": {
    "color": "#1e3a5f",
    "theme": "dark"
  },
  "activationEvents": [
    "workspaceContains:**/*.feature"
  ],
  "main": "./out/extension.js",
  "contributes": {},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.82.0",
    "@vscode/vsce": "^2.19.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "undici": "6.19.2"
  }
}
